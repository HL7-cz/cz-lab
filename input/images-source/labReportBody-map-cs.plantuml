"Tělo laboratorní zprávy" <|. "cz-service-request-lab"
"Tělo laboratorní zprávy" <|. "cz-specimen-lab"
"Tělo laboratorní zprávy" <|. "cz-observation-result-laboratory"
"Tělo laboratorní zprávy" <|. "cz-diagnostic-report-lab"
"Tělo laboratorní zprávy" <|. "cz-composition-lab-report"

"cz-service-request-lab" -d[hidden]-> "cz-specimen-lab"
"cz-specimen-lab" -d[hidden]-> "cz-observation-result-laboratory"
"cz-observation-result-laboratory" -d[hidden]-> "cz-diagnostic-report-lab"
"cz-diagnostic-report-lab" -d[hidden]-> "cz-composition-lab-report"
@enduml