@startuml labReportHead-map-en
hide circle
hide stereotype
hide members
hide methods
skinparam linetype ortho
skinparam class {
BackgroundColor<<LogicalModel>> #APPLICATION
BackgroundColor<<Profile>> #TECHNOLOGY
}
legend right
| <#APPLICATION>  Logical Model |
| <#TECHNOLOGY>  Profile |
endlegend
class "Laboratory Report Header" <<LogicalModel>> [[StructureDefinition-LabReportCz.html]]

class "cz-bundle-lab" <<Profile>> [[StructureDefinition-cz-bundle-lab.html]]
class "cz-composition-lab-report" <<Profile>> [[StructureDefinition-cz-composition-lab-report.html]]
class "cz-diagnostic-report-lab" <<Profile>> [[StructureDefinition-cz-diagnostic-report-lab.html]]
class "cz-patient" <<Profile>> [[https://build.fhir.org/ig/HL7-cz/cz-core/StructureDefinition-cz-patient-core.html]]
class "cz-coverage" <<Profile>> [[https://build.fhir.org/ig/HL7-cz/cz-core/StructureDefinition-cz-coverage.html]]
class "cz-practitioner-core" <<Profile>> [[https://build.fhir.org/ig/HL7-cz/cz-core/StructureDefinition-cz-practitioner-core.html]]
class "cz-practitionerRole-core" <<Profile>> [[https://build.fhir.org/ig/HL7-cz/cz-core/StructureDefinition-cz-practitioner-role-core.html]]
class "cz-organization-core" <<Profile>> [[https://build.fhir.org/ig/HL7-cz/cz-core/StructureDefinition-cz-organization-core.html]]

"Laboratory Report Header" <|. "cz-bundle-lab"
"Laboratory Report Header" <|. "cz-composition-lab-report"
"Laboratory Report Header" <|. "cz-diagnostic-report-lab"
"Laboratory Report Header" <|. "cz-patient"
"Laboratory Report Header" <|. "cz-coverage"
"Laboratory Report Header" <|. "cz-practitioner-core"
"Laboratory Report Header" <|. "cz-practitionerRole-core"
"Laboratory Report Header" <|. "cz-organization-core"

"cz-bundle-lab" -d[hidden]-> "cz-composition-lab-report"
"cz-composition-lab-report" -d[hidden]-> "cz-diagnostic-report-lab"
"cz-diagnostic-report-lab" -d[hidden]-> "cz-patient"
"cz-patient" -d[hidden]-> "cz-coverage"
"cz-coverage" -d[hidden]-> "cz-practitioner-core"
"cz-practitioner-core" -d[hidden]-> "cz-practitionerRole-core"
"cz-practitionerRole-core" -d[hidden]-> "cz-organization-core"
@enduml